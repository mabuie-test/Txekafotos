{
  "name": "txekafotos/platform",
  "description": "Plataforma MVC de pedidos de edição, restauração e composição de fotos com pagamentos M-Pesa via Débito.",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "ext-pdo": "*",
    "ext-json": "*",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "app/Core/Helpers.php"
    ]
  },
  "scripts": {
    "post-install-cmd": [
      "@php -r \"if (!is_dir('storage/logs')) mkdir('storage/logs', 0775, true);\""
    ],
    "serve": "php -S localhost:8000 -t public"
  },
  "config": {
    "sort-packages": true
  }
}
