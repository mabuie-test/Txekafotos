{
  "name": "txekafotos/platform",
  "description": "Plataforma MVC de pedidos de edição, restauração e composição de fotos com pagamentos M-Pesa via Débito.",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "ext-pdo": "*",
    "ext-json": "*",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "app/Core/Helpers.php"
    ]
  },
  "scripts": {
    "post-install-cmd": [
      "@php -r \"foreach (['storage', 'storage/logs', 'storage/temp', 'storage/uploads', 'storage/exports'] as $dir) { if (!is_dir($dir)) mkdir($dir, 0775, true); }\""
    ],
    "post-update-cmd": [
      "@composer post-install-cmd"
    ],
    "setup": [
      "@composer post-install-cmd",
      "@php -r \"if (!file_exists('.env') && file_exists('.env.example')) copy('.env.example', '.env');\""
    ],
    "setup-windows": [
      "@composer setup"
    ],
    "serve": "php -S localhost:8000 -t public"
  },
  "config": {
    "sort-packages": true
  }
}
